# Copy to .env.migrate and fill in your values
# Used by run_pgloader.sh

# MySQL (source) - data must already be in this database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=bjj_portal
MYSQL_USER=catch_user
MYSQL_PASSWORD=your_mysql_password

# Supabase (target) - from Dashboard → Settings → Database
# Host format: db.xxxxx.supabase.co (replace xxxxx with your project ref)
SUPABASE_HOST=db.xxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_supabase_database_password
